# Environment Variables Template for Video Violence Detection System Backend
# Copy this file to .env and fill in the values

# JWT Configuration (REQUIRED)
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database Configuration (REQUIRED)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai-video-violence-detection

# OpenAI Configuration (Optional - for future RAG endpoints)
# OPENAI_API_KEY=sk-...

# Qdrant Configuration (Optional - for future RAG endpoints)
# QDRANT_URL=http://localhost:6333
# QDRANT_COLLECTION_NAME=ai_video_violence_detection
