# Environment Variables Template for AI Video Violence Detection Backend
# Copy this file to .env and fill in the values

# JWT Configuration (REQUIRED)
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database Configuration (REQUIRED)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai-video-violence

# Default users (development only — set CREATE_DEFAULT_USERS=true for initial setup)
# Creates admin and user if they do not exist. Leave false in production.
CREATE_DEFAULT_USERS=true
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=Admin@123
DEFAULT_ADMIN_EMAIL=admin@localhost.com
DEFAULT_USER_USERNAME=user
DEFAULT_USER_PASSWORD=User@123
DEFAULT_USER_EMAIL=user@localhost.com

# GenAI — Incident explanation (optional; omit for mock/placeholder)
# Provider: Gemini (aligned with phase-04)
GEMINI_API_KEY=AIzaSyBkObiUYFB8CU8ZGj78xZgLZQUNh8CI9f0
GEMINI_MODEL=gemini-3-flash-preview

# Video upload (optional; defaults shown)
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10

# ML inference (optional; leave unset to use stub until a .keras model is available)
ML_MODEL_PATH=models/violence_model.keras
INFERENCE_BATCH_SIZE=16
TF_CPP_MIN_LOG_LEVEL=2
# Optional: set to 0 to disable oneDNN optimizations and suppress oneDNN startup note
TF_ENABLE_ONEDNN_OPTS=0

# Video preprocessing (frame extraction for ML; optional; defaults shown)
FRAME_EXTRACT_FPS=2.0
MODEL_INPUT_SIZE=64
MAX_FRAMES=32

# Rate limiting (optional; set RATELIMIT_ENABLED=false to disable, e.g. in tests)
RATELIMIT_ENABLED=true
RATELIMIT_DEFAULT=50 per hour
RATELIMIT_VIDEO_UPLOAD=5 per minute
RATELIMIT_VIDEO_ANALYSIS=10 per minute
